{
  "expo": {
    "name": "Hoxhë Abdulkadër Arnauti",
    "slug": "TAKVIM",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "takvim",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#002B45"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.takvim.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Takvim uses your location to show the Qibla direction for your current position."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#002B45"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.takvim.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/fab9c3c5-bb99-45cf-926b-8b2d6059ca8e"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#006233",
          "sounds": []
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "PrayerWidget",
              "label": "Takvim Prayers",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "Shows upcoming prayer times",
              "previewImage": "./assets/images/adaptive-icon.png"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "fab9c3c5-bb99-45cf-926b-8b2d6059ca8e"
      },
      "router": {}
    },
    "owner": "agronbajrami"
  }
}